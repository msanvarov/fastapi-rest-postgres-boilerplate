# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="FastAPI Async Boilerplate"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false           # true in production

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="change-me-to-a-long-random-string-of-at-least-64-chars-please"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800
POSTGRES_ECHO=false

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Concurrency tuning
# ---------------------------------------------------------------------------
# Caps on in-flight work — protects downstreams and the event loop.
DB_SEMAPHORE_LIMIT=50        # concurrent DB-bound coroutines per worker
HTTP_SEMAPHORE_LIMIT=100     # concurrent outbound HTTP calls per worker
CPU_SEMAPHORE_LIMIT=4        # concurrent CPU-bound tasks (run in threadpool)
TASK_QUEUE_MAX_SIZE=1000     # background task queue size
REQUEST_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
